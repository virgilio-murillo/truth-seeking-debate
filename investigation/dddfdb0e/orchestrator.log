import asyncio, time

# Verify elastic pool scale-up/down logic
async def test_elastic():
    MIN_WORKERS = 4
    MAX_WORKERS = 15
    SCALE_UP_THRESHOLD = 3   # scale up if queue > this
    IDLE_TIMEOUT = 5.0       # seconds before idle worker exits
    
    q = asyncio.Queue()
    workers = {}
    worker_count = [0]
    
    async def worker(wid):
        while True:
            try:
                item = await asyncio.wait_for(q.get(), timeout=IDLE_TIMEOUT)
                # process item
                q.task_done()
            except asyncio.TimeoutError:
                if len(workers) > MIN_WORKERS:
                    del workers[wid]
                    return  # graceful exit
    
    # Start minimum workers
    for i in range(MIN_WORKERS):
        t = asyncio.create_task(worker(i))
        workers[i] = t
    
    print(f'Started {len(workers)} workers (min={MIN_WORKERS})')
    
    # Simulate scale-up check
    for i in range(10):
        await q.put(i)
    
    if q.qsize() > SCALE_UP_THRESHOLD:
        needed = min(q.qsize() // 2, MAX_WORKERS - len(workers))
        for i in range(needed):
            wid = len(workers) + i
            t = asyncio.create_task(worker(wid))
            workers[wid] = t
        print(f'Scaled up to {len(workers)} workers (queue={q.qsize()})')
    
    await q.join()
    print(f'All items processed, workers={len(workers)}')
    for t in workers.values():
        t.cancel()

asyncio.run(test_elastic())
