# Verify the asyncio.Queue + worker pattern works
async def test():
    q = asyncio.Queue()
    results = []
    
    async def worker():
        while True:
            item = await asyncio.wait_for(q.get(), timeout=0.1)
            results.append(item)
            q.task_done()
    
    for i in range(5):
        await q.put(i)
    
    tasks = [asyncio.create_task(worker()) for _ in range(2)]
    await q.join()
    for t in tasks:
        t.cancel()
    print(f'Queue pattern works: processed {len(results)} items')

asyncio.run(test())
