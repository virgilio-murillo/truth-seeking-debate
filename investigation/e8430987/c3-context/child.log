"""Core primitives for spawning and managing kiro-cli agents."""

import os
import signal
import subprocess
import sys
import threading
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path


def _dbg(msg: str):
    """Debug print to a log file (stderr is not captured by kiro-cli)."""
    try:
        with open(os.path.expanduser("~/.kiro/kiro-agents-debug.log"), "a") as f:
            f.write(f"[{time.strftime('%H:%M:%S')} pid={os.getpid()}] {msg}\n")
            f.flush()
    except OSError:
        pass

# Ensure homebrew and local bins are in PATH
os.environ["PATH"] = os.path.expanduser("~/.local/bin") + ":/opt/homebrew/bin:" + os.environ.get("PATH", "")

# ── Safety limits ──
MAX_DEPTH = 3          # depth 0,1,2 allowed; 3 blocked
MAX_CHILDREN = 7      # max agents a single agent can spawn
MAX_SYSTEM_AGENTS = 30 # max total kiro-cli --no-interactive processes on machine
_DEPTH_ENV = "KIRO_AGENT_DEPTH"
_LAUNCH_LOCK = str(Path.home() / ".kiro/.agent-launch.lock")

# ── Job registry (shared in-process) ──
_jobs: dict[str, dict] = {}


def spawn_kiro(agent: str, task: str, work_dir: str, log_path: str, model: str = None) -> subprocess.Popen:
    """Spawn a kiro-cli agent process. Returns the Popen handle."""
    log_file = open(log_path, "w")
    cmd = [
        os.path.expanduser("~/.local/bin/kiro-cli"), "chat",
        "--no-interactive", "--trust-all-tools",
        "--agent", agent, "--wrap=never",
    ]
    if model:
        cmd.extend(["--model", model])
    cmd.append(f"skip confirmation. {task}")
    # Propagate depth to child via env
    current_depth = int(os.environ.get(_DEPTH_ENV, "0"))
    env = {**os.environ, _DEPTH_ENV: str(current_depth + 1)}
    _dbg(f"spawn_kiro: agent={agent} depth={current_depth+1} cwd={work_dir}")
    proc = subprocess.Popen(
        cmd, stdout=log_file, stderr=subprocess.STDOUT,
        cwd=work_dir, start_new_session=True, env=env,
    )
    _dbg(f"spawn_kiro: pid={proc.pid} pgid={os.getpgid(proc.pid)}")
    return proc


def is_done(proc) -> bool:
    if isinstance(proc, str):
        return True
    return proc.poll() is not None


def kill_proc(proc):
    if isinstance(proc, subprocess.Popen) and proc.poll() is None:
        pid = proc.pid
        try:
            pgid = os.getpgid(pid)
        except ProcessLookupError:
            _dbg(f"kill_proc: pid={pid} already gone (getpgid failed)")
            return
        _dbg(f"kill_proc: sending SIGTERM to pgid={pgid} (pid={pid})")
        try:
            os.killpg(pgid, signal.SIGTERM)
        except ProcessLookupError:
            _dbg(f"kill_proc: pgid={pgid} gone before SIGTERM")
            return
        _dbg(f"kill_proc: waiting up to 5s for pid={pid}")
        try:
            proc.wait(timeout=5)
            _dbg(f"kill_proc: pid={pid} exited after SIGTERM (rc={proc.returncode})")
            return
        except subprocess.TimeoutExpired:
            _dbg(f"kill_proc: pid={pid} did NOT exit after 5s SIGTERM, sending SIGKILL")
            try:
                os.killpg(pgid, signal.SIGKILL)
            except ProcessLookupError:
                _dbg(f"kill_proc: pgid={pgid} gone before SIGKILL")
                return
            _dbg(f"kill_proc: waiting up to 10s for pid={pid} after SIGKILL")
            try:
                proc.wait(timeout=10)
                _dbg(f"kill_proc: pid={pid} exited after SIGKILL (rc={proc.returncode})")
            except subprocess.TimeoutExpired:
                _dbg(f"kill_proc: pid={pid} STILL ALIVE after SIGKILL+10s — zombie or unkillable")
    else:
        _dbg(f"kill_proc: proc already done (poll={proc.poll() if isinstance(proc, subprocess.Popen) else 'str'})")


def tail(path: str, n: int = 20) -> str:
    try:
        t0 = time.time()
        f = Path(path)
        size = f.stat().st_size
        # Read at most last 64KB to avoid blocking on large logs
        max_bytes = 65536
        if size > max_bytes:
            with open(path, "rb") as fh:
                fh.seek(-max_bytes, 2)
                data = fh.read().decode("utf-8", errors="replace")
        else:
            data = f.read_bytes().decode("utf-8", errors="replace")
        lines = data.splitlines()
        elapsed = time.time() - t0
        if elapsed > 1.0:
            _dbg(f"tail: SLOW read {path} size={size} took {elapsed:.2f}s")
        return "\n".join(lines[-n:])
    except (FileNotFoundError, OSError) as e:
        _dbg(f"tail: error reading {path}: {e}")
        return "(no output yet)"


def open_ghostty_tab(command: str):
    """Open a new Ghostty tab via native AppleScript API."""
    script = (
        'tell application "Ghostty"\n'
        '  set cfg to new surface configuration\n'
        f'  set command of cfg to "{command}"\n'
        '  new tab in front window with configuration cfg\n'
        'end tell'
    )
    subprocess.Popen(["osascript", "-e", script], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def launch(agent: str, task: str, work_dir: str, model: str = None) -> str:
    """Launch an agent and return a job_id. Registers in _jobs."""
    # ── Safety: depth limit ──
    current_depth = int(os.environ.get(_DEPTH_ENV, "0"))
    if current_depth >= MAX_DEPTH:
        raise RuntimeError(
            f"Agent depth limit reached ({current_depth}/{MAX_DEPTH}). "
            f"Cannot spawn '{agent}'. Complete the task with available tools instead."
        )
    # ── Safety: per-agent children limit ──
    children = sum(1 for j in _jobs.values() if j["phase"] == "running" and not is_done(j["proc"]))
    if children >= MAX_CHILDREN:
        raise RuntimeError(
            f"Children limit reached ({children}/{MAX_CHILDREN}). "
            f"Wait for running agents to finish before launching '{agent}'."
        )
    # ── Safety: system-wide agent limit (file-locked to prevent race) ──
    import fcntl
    with open(_LAUNCH_LOCK, "a") as lockf:
        # Non-blocking lock attempt with retry to avoid indefinite hangs
        for attempt in range(10):
            try:
                fcntl.flock(lockf, fcntl.LOCK_EX | fcntl.LOCK_NB)
                break
            except BlockingIOError:
                if attempt == 9:
                    raise RuntimeError(
                        f"Cannot acquire agent launch lock after 10 attempts. "
                        f"Another process may be stuck. Try: rm {_LAUNCH_LOCK}"
                    )
                import time as _time
                _time.sleep(0.5)
        try:
            count = int(subprocess.check_output(
                ["pgrep", "-f", "kiro-cli.*--no-interactive"],
                stderr=subprocess.DEVNULL, timeout=5
            ).decode().strip().count("\n")) + 1
        except (subprocess.CalledProcessError, ValueError, subprocess.TimeoutExpired):
            count = 0
        if count >= MAX_SYSTEM_AGENTS:
            raise RuntimeError(
                f"System agent limit reached ({count}/{MAX_SYSTEM_AGENTS}). "
                f"Cannot spawn '{agent}'. Too many agents running on this machine."
            )

        job_id = str(uuid.uuid4())[:8]
        out_dir = str(Path(work_dir) / ".kiro-agents" / job_id)
        os.makedirs(out_dir, exist_ok=True)
        log_path = str(Path(out_dir) / "agent.log")

        proc = spawn_kiro(agent, task, work_dir, log_path, model)

    # Persist metadata for kiro-pulse analysis
    import json as _json
    Path(out_dir, "meta.json").write_text(_json.dumps({
        "job_id": job_id, "agent": agent, "task": task[:500],
        "work_dir": work_dir, "started_at": datetime.now(timezone.utc).isoformat(),
    }))

    _jobs[job_id] = {
        "job_id": job_id, "agent": agent, "task": task,
        "work_dir": work_dir, "out_dir": out_dir,
        "log_path": log_path, "proc": proc,
        "phase": "running", "_start_time": time.time(),
    }

    def _monitor():
        COMPLETION_MARKER = b"\x1b]9;Response complete\x07"
        last_size = -1
        stale_since = None
        _dbg(f"monitor[{job_id}]: started for pid={proc.pid}")
        while proc.poll() is None:
            time.sleep(5)
            try:
                data = Path(job["log_path"]).read_bytes()
            except OSError:
                continue
            size = len(data)
            if size != last_size:
                last_size = size
                stale_since = None
            else:
                if stale_since is None:
                    stale_since = time.time()
                    _dbg(f"monitor[{job_id}]: output stale at size={size}")
                stale_secs = time.time() - stale_since
                if COMPLETION_MARKER in data and stale_secs >= 30:
                    _dbg(f"monitor[{job_id}]: completion marker found + stale {stale_secs:.0f}s — marking complete")
                    break  # task done, process stuck in shutdown
                if stale_secs >= 300:
                    _dbg(f"monitor[{job_id}]: 5-min staleness timeout — marking complete")
                    break  # safety net: 5-min absolute staleness
        rc = proc.poll()
        _dbg(f"monitor[{job_id}]: exiting. proc.poll()={rc}")
        _jobs[job_id]["phase"] = "complete"

    threading.Thread(target=_monitor, daemon=True).start()
    return job_id


def get_status(job_id: str) -> dict | None:
    job = _jobs.get(job_id)
    if not job:
        return None
    proc = job["proc"]
    done = is_done(proc)
    phase = job["phase"] if job["phase"] in ("stopped", "complete") else ("complete" if done else "running")
    return {
        "job_id": job_id, "agent": job["agent"],
        "phase": phase,
        "exit_code": proc.returncode if done and isinstance(proc, subprocess.Popen) else None,
        "log_tail": tail(job["log_path"], 15),
    }


def get_result(job_id: str) -> str | None:
    job = _jobs.get(job_id)
    if not job:
        return None
    return tail(job["log_path"], 200)


def stop(job_id: str) -> bool:
    job = _jobs.get(job_id)
    if not job:
        return False
    kill_proc(job["proc"])
    job["phase"] = "stopped"
    return True
